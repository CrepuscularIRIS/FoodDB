{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Regulatory Events Schema",
  "description": "监管事件记录表（处罚/整改/投诉/抽检异常）",
  "type": "object",
  "required": [
    "event_id",
    "enterprise_id",
    "event_type",
    "event_date",
    "severity",
    "description"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "description": "事件唯一标识",
      "pattern": "^EVT-[0-9]{6}$"
    },
    "enterprise_id": {
      "type": "string",
      "description": "涉事企业ID",
      "pattern": "^ENT-[0-9]{4}$"
    },
    "event_type": {
      "type": "string",
      "enum": ["处罚", "整改", "投诉", "抽检异常", "召回", "媒体曝光"],
      "description": "事件类型"
    },
    "event_date": {
      "type": "string",
      "description": "事件发生日期(YYYY-MM-DD)",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "severity": {
      "type": "string",
      "enum": ["high", "medium", "low"],
      "description": "严重程度"
    },
    "description": {
      "type": "string",
      "description": "事件描述"
    },
    "related_batch_id": {
      "type": ["string", "null"],
      "description": "关联批次ID",
      "pattern": "^BATCH-[0-9]{6}$"
    },
    "violation_type": {
      "type": ["string", "null"],
      "enum": ["微生物超标", "添加剂违规", "标签违规", "质量指标", "其他"],
      "description": "违规类型 - 可选"
    },
    "penalty_amount": {
      "type": ["number", "null"],
      "description": "罚款金额(元) - 可选",
      "minimum": 0
    },
    "rectification_deadline": {
      "type": ["string", "null"],
      "description": "整改期限(YYYY-MM-DD) - 可选",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "rectification_status": {
      "type": ["string", "null"],
      "enum": ["未整改", "整改中", "已整改"],
      "description": "整改状态 - 可选"
    },
    "source_url": {
      "type": ["string", "null"],
      "description": "信息来源URL - 可选"
    },
    "region": {
      "type": ["string", "null"],
      "description": "所属区域 - 可选"
    }
  }
}
