{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Enterprise Master Schema",
  "description": "乳制品供应链企业主数据表",
  "type": "object",
  "required": [
    "enterprise_id",
    "enterprise_name",
    "enterprise_type",
    "node_type",
    "address",
    "license_no",
    "credit_rating",
    "historical_violation_count",
    "supervision_freq",
    "haccp_certified",
    "iso22000_certified"
  ],
  "properties": {
    "enterprise_id": {
      "type": "string",
      "description": "企业唯一标识",
      "pattern": "^ENT-[0-9]{4}$"
    },
    "enterprise_name": {
      "type": "string",
      "description": "企业名称"
    },
    "enterprise_type": {
      "type": "string",
      "enum": ["large", "medium", "small", "micro"],
      "description": "企业规模"
    },
    "node_type": {
      "type": "string",
      "enum": ["牧场", "乳企", "物流", "仓储", "零售"],
      "description": "节点类型"
    },
    "address": {
      "type": "string",
      "description": "企业地址"
    },
    "latitude": {
      "type": ["number", "null"],
      "description": "纬度（可选）",
      "minimum": -90,
      "maximum": 90
    },
    "longitude": {
      "type": ["number", "null"],
      "description": "经度（可选）",
      "minimum": -180,
      "maximum": 180
    },
    "license_no": {
      "type": "string",
      "description": "食品生产许可证号(SC证)"
    },
    "credit_rating": {
      "type": "string",
      "enum": ["A", "B", "C", "D"],
      "description": "信用等级"
    },
    "historical_violation_count": {
      "type": "integer",
      "description": "历史违规次数",
      "minimum": 0
    },
    "supervision_freq": {
      "type": "integer",
      "description": "年度监管频次",
      "minimum": 0
    },
    "haccp_certified": {
      "type": "boolean",
      "description": "是否通过HACCP认证"
    },
    "iso22000_certified": {
      "type": "boolean",
      "description": "是否通过ISO22000认证"
    },
    "production_capacity_daily": {
      "type": ["number", "null"],
      "description": "日产能(吨) - 模拟数据"
    },
    "main_products": {
      "type": ["string", "null"],
      "description": "主要产品 - 模拟数据"
    },
    "establishment_date": {
      "type": ["string", "null"],
      "description": "成立日期(YYYY-MM-DD) - 模拟数据",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    }
  }
}
