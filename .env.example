# ========================================
# FoodDB 项目环境配置模板
# ========================================

# 复制此文件为 .env 并填入你的 API Key
# cp .env.example .env

# --- MiniMax LLM API (用于风险分析) ---
MINIMAX_API_KEY=your-minimax-api-key
MINIMAX_GROUP_ID=not-required
MINIMAX_MODEL=MiniMax-M2.5

# --- 可选配置 ---
# USE_MOCK_LLM=true  # 强制使用 Mock 模式
