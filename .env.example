# ========================================
# 乳制品供应链风险研判系统 - 环境配置
# ========================================

# --- Minimax LLM API 配置 ---
# 获取API密钥: https://www.minimaxi.com/
MINIMAX_API_KEY=your-api-key-here
MINIMAX_GROUP_ID=not-required
MINIMAX_MODEL=MiniMax-M2.5
MINIMAX_TEMPERATURE=0.3
MINIMAX_MAX_TOKENS=4096

# --- 可选配置 ---
# 强制使用 Mock 模式 (用于测试)
# USE_MOCK_LLM=true
