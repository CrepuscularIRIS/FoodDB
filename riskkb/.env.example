# MiniMax LLM API Configuration
# 获取API密钥: https://www.minimaxi.com/
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_GROUP_ID=your_group_id_here
MINIMAX_MODEL=MiniMax-M2.5
MINIMAX_TEMPERATURE=0.3
MINIMAX_MAX_TOKENS=4096

# Optional: Force mock mode for testing
# USE_MOCK_LLM=true

# External Data Sources (Optional)
# PubMed API: https://www.ncbi.nlm.nih.gov/home/develop/api/
PubMed-API-KEY=your_pubmed_api_key

# OpenFDA API: https://open.fda.gov/apis/
openFDA-API-KEY=your_openfda_api_key

# HuggingFace Token (Optional)
Huggingface-Token=your_hf_token
